{
    "name": "wedding/backend",
    "description": "Wedding App Backend - CodeIgniter 4",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "codeigniter4/framework": "4.4.*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.2",
        "kint-php/kint": "5.0",
        "mikey179/vfsstream": "^1.6.11",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/support/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ]
    },
    "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "audit": {
        "block-insecure": false
    }
},
    "minimum-stability": "stable",
    "prefer-stable": true
}
